    "@types/node": "^22",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "browserslist": "^4.28.2",
    "esbuild": "~0.28.0",
    "knip": "^6.12.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
